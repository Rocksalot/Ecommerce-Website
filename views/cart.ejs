<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<%- include('partials/header') %>

<div class="cart-page">
  <div class="container">
    <h1 class="cart-title">My cart (<%= cartItems.length %>)</h1>

    <div class="cart-layout">

      <!-- Cart Items -->
      <div>
        <% if (cartItems.length === 0) { %>
          <div style="text-align:center;padding:60px;border:1px solid var(--border);border-radius:var(--radius)">
            <div style="font-size:64px">🛒</div>
            <h3 style="margin:16px 0 8px">Your cart is empty</h3>
            <p style="color:var(--text-muted);margin-bottom:20px">Browse our products and add items to your cart</p>
            <a href="/products" class="btn btn-primary">Browse Products</a>
          </div>
        <% } else { %>
          <% cartItems.forEach(item => { %>
          <div class="cart-item">
            <img src="<%= item.product.image %>" alt="<%= item.product.name %>" onerror="this.src='/images/img.jpg'" />
            <div class="cart-item-info">
              <div class="cart-item-name"><%= item.product.name %></div>
              <div class="cart-item-meta">
                Size: medium, Color: blue, Material: Plastic<br>
                Seller: Artel Market
              </div>
              <div class="cart-item-actions">
                <form action="/cart/remove" method="POST" style="display:inline">
                  <input type="hidden" name="productId" value="<%= item.productId %>" />
                  <button type="submit" class="btn btn-outline btn-sm">Remove</button>
                </form>
                <form action="/cart/save-later" method="POST" style="display:inline">
                  <input type="hidden" name="productId" value="<%= item.productId %>" />
                  <button type="submit" class="btn btn-outline btn-sm" style="color:var(--blue);border-color:var(--blue)">Save for later</button>
                </form>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:10px">
              <div class="cart-item-price">$<%= (item.product.price * item.quantity).toFixed(2) %></div>
              <form action="/cart/update" method="POST">
                <input type="hidden" name="productId" value="<%= item.productId %>" />
                <select name="quantity" class="cart-qty" onchange="this.form.submit()">
                  <% for (let q = 1; q <= 20; q++) { %>
                    <option value="<%= q %>" <%= item.quantity === q ? 'selected' : '' %>>Qty: <%= q %></option>
                  <% } %>
                </select>
              </form>
            </div>
          </div>
          <% }) %>

          <div class="cart-actions">
            <a href="/products" class="btn btn-primary">← Back to shop</a>
            <form action="/cart/clear" method="POST" onsubmit="return confirm('Remove all items?')">
              <button type="submit" class="btn btn-outline" style="color:var(--red);border-color:var(--red)">Remove all</button>
            </form>
          </div>
        <% } %>

        <!-- Trust Badges -->
        <div class="trust-badges" style="margin-top:20px">
          <div class="trust-badge">🔒 <div><strong>Secure payment</strong><br><small style="color:var(--text-muted)">100% protected</small></div></div>
          <div class="trust-badge">💬 <div><strong>Customer support</strong><br><small style="color:var(--text-muted)">24/7 available</small></div></div>
          <div class="trust-badge">🚚 <div><strong>Free delivery</strong><br><small style="color:var(--text-muted)">On orders over $50</small></div></div>
        </div>

        <!-- Saved For Later -->
        <% if (savedItems.length > 0) { %>
        <div class="saved-later-section">
          <h3>Saved for later (<%= savedItems.length %>)</h3>
          <div class="saved-grid">
            <% savedItems.forEach(item => { %>
            <div class="saved-card">
              <img src="<%= item.product.image %>" alt="<%= item.product.name %>" onerror="this.src='/images/img.jpg'" />
              <div class="saved-card-info">
                <div class="price">$<%= Number(item.product.price).toFixed(2) %></div>
                <div class="name"><%= item.product.name %></div>
                <form action="/cart/move-to-cart" method="POST">
                  <input type="hidden" name="productId" value="<%= item.productId %>" />
                  <button type="submit" class="btn btn-outline btn-sm" style="width:100%">🛒 Move to cart</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Order Summary -->
      <div class="cart-summary">
        <div class="coupon-input">
          <input type="text" class="form-control" placeholder="Add coupon" />
          <button class="btn btn-primary btn-sm">Apply</button>
        </div>

        <div class="summary-row">
          <span>Subtotal:</span>
          <span>$<%= subtotal.toFixed(2) %></span>
        </div>
        <% if (discount > 0) { %>
        <div class="summary-row">
          <span>Discount:</span>
          <span class="discount-text">- $<%= discount.toFixed(2) %></span>
        </div>
        <% } %>
        <div class="summary-row">
          <span>Tax (1%):</span>
          <span class="tax-text">+ $<%= tax.toFixed(2) %></span>
        </div>
        <hr class="summary-divider" />
        <div class="summary-row summary-total">
          <span>Total:</span>
          <span>$<%= total.toFixed(2) %></span>
        </div>

        <% if (cartItems.length > 0) { %>
          <a href="#" class="btn btn-green btn-full" style="margin-top:16px;font-size:15px">Checkout</a>
        <% } else { %>
          <button class="btn btn-green btn-full" style="margin-top:16px;font-size:15px;opacity:0.5" disabled>Checkout</button>
        <% } %>

        <div class="payment-icons" style="margin-top:12px">
          <span title="American Express">💳</span>
          <span title="Mastercard">💳</span>
          <span title="PayPal">🅿</span>
          <span title="Visa">💳</span>
          <span title="Apple Pay">🍎</span>
        </div>
      </div>

    </div>

    <!-- Discount Banner -->
    <div class="discount-banner" style="margin-top:32px">
      <div>
        <h2>Super discount on more than 100 USD</h2>
        <p>Have you ever finally just write dummy info</p>
      </div>
      <a href="/products" class="btn btn-orange">Shop now</a>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
</body>
</html>
