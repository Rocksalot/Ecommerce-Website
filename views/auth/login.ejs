<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <h2>Sign in</h2>
    <p class="subtitle">Don't have an account? <a href="/auth/signup">Register</a></p>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><%= error[0] %></div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label for="email">Email address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="Enter email" required />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required />
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;font-size:13px">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer">
          <input type="checkbox" /> Remember me
        </label>
        <a href="#" style="color:var(--blue)">Forgot password?</a>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign in</button>
    </form>

    <div style="text-align:center;margin:16px 0;color:var(--text-muted);font-size:13px">— OR —</div>

    <button class="btn btn-outline btn-full" style="margin-bottom:8px">
      <span>🌐</span> Continue with Google
    </button>
    <button class="btn btn-outline btn-full">
      <span>🍎</span> Continue with Apple
    </button>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
